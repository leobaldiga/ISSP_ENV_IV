riskper <- c('indpol20', 'crpent20', 'pstent20', 'rlpent20', 'tmpent20')
#create additive index 'enatt20' and 'enatt20_mean' for env_concerns variables, removing '6'
Assignment_3 <- Postcoded %>%
mutate(across(all_of(env_concerns), ~ ifelse(. == 6, NA, .))) %>% #replace 6 with NA
mutate(enatt20 = rowSums(.[env_concerns], na.rm = TRUE),
enatt20_mean = rowMeans(.[env_concerns], na.rm = TRUE)) %>%
mutate(across(all_of(wtp), ~ ifelse(. == 6, NA, .))) %>% #replace 6 with NA
mutate(wtp20 = rowSums(.[wtp], na.rm = TRUE),
wtp20_mean = rowMeans(.[wtp], na.rm = TRUE)) %>%
mutate(across(all_of(riskper), ~ ifelse(. == 6, NA, .))) %>% #replace 6 with NA
mutate(riskper20 = rowSums(.[riskper], na.rm = TRUE),
riskper20_mean = rowMeans(.[riskper], na.rm = TRUE))
risk_hist <- ggplot(Assignment_3, aes(x = riskper20_mean)) +
geom_histogram(fill = "lightgreen") +
ggtitle("Histogram of Risk Perception") +
labs(x = "Risk Perception", y = "Frequency") +
theme_minimal()
print(risk_hist)
#by country in a grid of histograms
risk_country <- ggplot(Assignment_3, aes(x = riskper20_mean)) +
geom_histogram(fill = "lightgreen") +
facet_wrap(~country, scales = "fixed") +
ggtitle("Histogram of Risk Perception by Country") +
labs(x = "Risk Perception", y = "Frequency") +
theme_minimal()
plot(risk_country)
