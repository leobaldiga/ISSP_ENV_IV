geom_histogram(data = Assignment_3, aes(x = wtp20_mean, fill = "Willingness to Pay"), alpha = 0.5, position = "identity", bins = 20) +
facet_wrap(~country, scales = "fixed") +
ggtitle("Histogram of Environmental Concerns and Willingness to Pay") +
labs(x = "Environmental Concerns and Willingness to Pay", y = "Frequency") +
theme_minimal()
print(hist_overlap)
