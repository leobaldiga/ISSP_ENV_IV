PH_CINC = ifelse(PH_RINC > PH_CINC, PH_RINC, PH_CINC),
RU_CINC = ifelse(RU_RINC > RU_CINC, RU_RINC, RU_CINC),
SE_CINC = ifelse(SE_RINC > SE_CINC, SE_RINC, SE_CINC),
SI_CINC = ifelse(SI_RINC > SI_CINC, SI_RINC, SI_CINC),
SK_CINC = ifelse(SK_RINC > SK_CINC, SK_RINC, SK_CINC),
TH_CINC = ifelse(TH_RINC > TH_CINC, TH_RINC, TH_CINC),
TW_CINC = ifelse(TW_RINC > TW_CINC, TW_RINC, TW_CINC),
US_CINC = ifelse(US_RINC > US_CINC, US_RINC, US_CINC),
ZA_CINC = ifelse(ZA_RINC > ZA_CINC, ZA_RINC, ZA_CINC)
) %>% #replace any remaining NAs with INC values
mutate(
AT_CINC = ifelse(is.na(AT_CINC), AT_INC, AT_CINC),
AU_CINC = ifelse(is.na(AU_CINC), AU_INC, AU_CINC),
CH_CINC = ifelse(is.na(CH_CINC), CH_INC, CH_CINC),
CN_CINC = ifelse(is.na(CN_CINC), CN_INC, CN_CINC),
DE_CINC = ifelse(is.na(DE_CINC), DE_INC, DE_CINC),
DK_CINC = ifelse(is.na(DK_CINC), DK_INC, DK_CINC),
ES_CINC = ifelse(is.na(ES_CINC), ES_INC, ES_CINC),
