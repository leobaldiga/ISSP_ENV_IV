FI_CINC = ifelse(FI_RINC > FI_CINC, FI_RINC, FI_CINC),
FR_CINC = ifelse(FR_RINC > FR_CINC, FR_RINC, FR_CINC),
HR_CINC = ifelse(HR_RINC > HR_CINC, HR_RINC, HR_CINC),
HU_CINC = ifelse(HU_RINC > HU_CINC, HU_RINC, HU_CINC),
