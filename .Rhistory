SK_CINC = SK_CINC / HOMPOP,
TH_CINC = TH_CINC / HOMPOP,
TW_CINC = TW_CINC / HOMPOP,
US_CINC = US_CINC / HOMPOP,
ZA_CINC = ZA_CINC / HOMPOP
) %>% #log10 the values and add 1 to each to avoid log(0)
mutate(
AT_CINC = log10(AT_CINC + 1),
AU_CINC = log10(AU_CINC + 1),
CH_CINC = log10(CH_CINC + 1),
CN_CINC = log10(CN_CINC + 1),
DE_CINC = log10(DE_CINC + 1),
DK_CINC = log10(DK_CINC + 1),
ES_CINC = log10(ES_CINC + 1),
