SK_CINC = ifelse(is.na(SK_CINC), SK_INC, SK_CINC),
TH_CINC = ifelse(is.na(TH_CINC), TH_INC, TH_CINC),
TW_CINC = ifelse(is.na(TW_CINC), TW_INC, TW_CINC),
US_CINC = ifelse(is.na(US_CINC), US_INC, US_CINC),
ZA_CINC = ifelse(is.na(ZA_CINC), ZA_INC, ZA_CINC)
) %>% #divide by HOMPOP to adjust for household size
mutate(
AT_CINC = AT_CINC / HOMPOP,
AU_CINC = AU_CINC / HOMPOP,
CH_CINC = CH_CINC / HOMPOP,
CN_CINC = CN_CINC / HOMPOP,
DE_CINC = DE_CINC / HOMPOP,
