IT_CINC = ifelse(is.na(IT_CINC), IT_INC, IT_CINC),
JP_CINC = ifelse(is.na(JP_CINC), JP_INC, JP_CINC),
KR_CINC = ifelse(is.na(KR_CINC), KR_INC, KR_CINC),
LT_CINC = ifelse(is.na(LT_CINC), LT_INC, LT_CINC),
NO_CINC = ifelse(is.na(NO_CINC), NO_INC, NO_CINC),
NZ_CINC = ifelse(is.na(NZ_CINC), NZ_INC, NZ_CINC),
PH_CINC = ifelse(is.na(PH_CINC), PH_INC, PH_CINC),
RU_CINC = ifelse(is.na(RU_CINC), RU_INC, RU_CINC),
SE_CINC = ifelse(is.na(SE_CINC), SE_INC, SE_CINC),
