JP_CINC = log10(JP_CINC + 1),
KR_CINC = log10(KR_CINC + 1),
LT_CINC = log10(LT_CINC + 1),
NO_CINC = log10(NO_CINC + 1),
NZ_CINC = log10(NZ_CINC + 1),
